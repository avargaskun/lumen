# Benchmark configuration
# Source this file: . config.env

# Number of trials per arm per task
BENCH_TRIALS=5

# Claude model to use
BENCH_MODEL="claude-sonnet-4-20250514"

# Temperature (use default for realistic variance)
BENCH_TEMPERATURE=1

# Directory for cloned repos
BENCH_REPOS_DIR="${BENCH_REPOS_DIR:-/tmp/lumen-bench-repos}"

# Directory for results
BENCH_RESULTS_DIR="${BENCH_RESULTS_DIR:-$(dirname "$0")/../results}"

# Path to lumen binary
LUMEN_BIN="${LUMEN_BIN:-$(dirname "$0")/../../bin/lumen-$(uname -s | tr '[:upper:]' '[:lower:]')-$(uname -m)}"

# MCP config for lumen treatment arm
BENCH_MCP_CONFIG="$(dirname "$0")/../fixtures/lumen-mcp.json"

# Timeout per trial (seconds)
BENCH_TIMEOUT=300

# Max tokens per trial
BENCH_MAX_TOKENS=100000
